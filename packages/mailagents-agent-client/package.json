{
  "name": "@mailagents/agent-client",
  "version": "0.1.0",
  "type": "module",
  "description": "Lightweight Mailagents agent client for runtime discovery, mailbox-first HTTP flows, and MCP tool calls.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haocn-ops/mailagents-email-runtime.git",
    "directory": "packages/mailagents-agent-client"
  },
  "homepage": "https://github.com/haocn-ops/mailagents-email-runtime/tree/main/packages/mailagents-agent-client",
  "bugs": {
    "url": "https://github.com/haocn-ops/mailagents-email-runtime/issues"
  },
  "keywords": [
    "mailagents",
    "agent",
    "mcp",
    "email",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "pack:dry-run": "npm pack --dry-run",
    "publish:dry-run": "npm publish --dry-run --access public"
  }
}
