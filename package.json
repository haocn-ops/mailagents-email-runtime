{
  "name": "mailagents-cloudflare2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "check:agent-client": "npm --workspace @mailagents/agent-client run check",
    "build:agent-client": "npm --workspace @mailagents/agent-client run build",
    "pack:agent-client:dry-run": "npm --workspace @mailagents/agent-client run pack:dry-run",
    "publish:agent-client:dry-run": "npm --workspace @mailagents/agent-client run publish:dry-run",
    "deploy": "wrangler deploy --env production",
    "deploy:dev": "wrangler deploy --env dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "dev": "wrangler dev",
    "dev:local": "wrangler dev --local --persist-to .wrangler/state",
    "config:check": "bash ./scripts/check_config.sh production",
    "config:check:dev": "bash ./scripts/check_config.sh dev",
    "config:check:staging": "bash ./scripts/check_config.sh staging",
    "config:check:production": "bash ./scripts/check_config.sh production",
    "d1:migrate:local": "bash ./scripts/d1_migrate.sh local",
    "d1:migrate:remote:dev": "bash ./scripts/d1_migrate.sh dev",
    "d1:migrate:remote:staging": "bash ./scripts/d1_migrate.sh staging",
    "d1:migrate:remote:production": "bash ./scripts/d1_migrate.sh production",
    "d1:seed:local": "wrangler d1 execute mailagents-local --local --file=./seeds/0001_demo.sql",
    "d1:seed:remote:dev": "wrangler d1 execute mailagents-dev --remote --env dev --file=./seeds/0001_demo.sql",
    "d1:seed:remote:staging": "wrangler d1 execute mailagents-staging --remote --env staging --file=./seeds/0001_demo.sql",
    "d1:seed:remote:production": "wrangler d1 execute mailagents-production --remote --env production --file=./seeds/0001_demo.sql",
    "smoke:local": "bash ./scripts/local_smoke.sh",
    "smoke:local:auto": "bash ./scripts/run_local_smoke_with_worker.sh ./scripts/local_smoke.sh",
    "smoke:billing:local": "X402_PAY_TO=0x1111111111111111111111111111111111111111 X402_FACILITATOR_URL=mock://local PAYMENT_CONFIRM_MODE_FOR_SMOKE=facilitator bash ./scripts/billing_did_smoke.sh",
    "smoke:billing:local:auto": "X402_PAY_TO=0x1111111111111111111111111111111111111111 X402_FACILITATOR_URL=mock://local PAYMENT_CONFIRM_MODE_FOR_SMOKE=facilitator bash ./scripts/run_local_smoke_with_worker.sh ./scripts/billing_did_smoke.sh",
    "smoke:billing:facilitator:local": "X402_PAY_TO=0x1111111111111111111111111111111111111111 X402_FACILITATOR_URL=mock://local PAYMENT_CONFIRM_MODE_FOR_SMOKE=facilitator bash ./scripts/billing_did_smoke.sh",
    "smoke:billing:facilitator:local:auto": "X402_PAY_TO=0x1111111111111111111111111111111111111111 X402_FACILITATOR_URL=mock://local PAYMENT_CONFIRM_MODE_FOR_SMOKE=facilitator bash ./scripts/run_local_smoke_with_worker.sh ./scripts/billing_did_smoke.sh",
    "smoke:upgrade-unlock:local:auto": "API_SIGNING_SECRET_FOR_SMOKE=local-signing-secret X402_PAY_TO=0x1111111111111111111111111111111111111111 X402_FACILITATOR_URL=mock://local PAYMENT_CONFIRM_MODE_FOR_SMOKE=facilitator SES_MOCK_SEND=true SES_MOCK_SEND_DELAY_MS=1500 bash ./scripts/run_local_smoke_with_worker.sh ./scripts/upgrade_external_unlock_smoke.sh",
    "smoke:billing:dev:real-chain": "bash ./scripts/dev_real_chain_topup_smoke.sh",
    "smoke:billing:dev:real-chain:facilitator": "PAYMENT_CONFIRM_MODE_FOR_SMOKE=facilitator bash ./scripts/dev_real_chain_topup_smoke.sh",
    "smoke:billing:dev:real-chain:upgrade": "bash ./scripts/dev_real_chain_upgrade_smoke.sh",
    "smoke:signup:local": "bash ./scripts/signup_site_smoke.sh",
    "smoke:signup:local:auto": "SES_MOCK_SEND=true SES_MOCK_SEND_DELAY_MS=1500 bash ./scripts/run_local_smoke_with_worker.sh ./scripts/signup_site_smoke.sh",
    "smoke:credits:local": "bash ./scripts/outbound_credit_smoke.sh",
    "smoke:credits:local:auto": "SES_MOCK_SEND=true SES_MOCK_SEND_DELAY_MS=1500 bash ./scripts/run_local_smoke_with_worker.sh ./scripts/outbound_credit_smoke.sh",
    "smoke:uncertain:local": "bash ./scripts/outbound_uncertain_resolution_smoke.sh",
    "smoke:uncertain:local:auto": "bash ./scripts/run_local_smoke_with_worker.sh ./scripts/outbound_uncertain_resolution_smoke.sh",
    "smoke:mcp:local": "bash ./scripts/mcp_smoke.sh",
    "smoke:mcp:local:auto": "bash ./scripts/run_local_smoke_with_worker.sh ./scripts/mcp_smoke.sh",
    "smoke:mcp:dev": "BASE_URL=https://mailagents-dev.izhenghaocn.workers.dev bash ./scripts/mcp_smoke.sh",
    "smoke:production:readonly": "bash ./scripts/production_readonly_smoke.sh",
    "check:reply-threading": "bash ./scripts/reply_threading_regression_check.sh",
    "diagnose:production:live": "bash ./scripts/production_live_drift_check.sh",
    "verify:production:readonly": "bash ./scripts/production_postdeploy_verify.sh",
    "faucet:cdp": "node ./scripts/request_cdp_faucet.mjs",
    "backfill:subjects:dev": "node ./scripts/backfill_message_subjects.mjs --env dev",
    "backfill:subjects:production": "node ./scripts/backfill_message_subjects.mjs --env production",
    "example:agent:discover": "node ./examples/discover_agent_capabilities.mjs",
    "example:agent:discover-admin": "node ./examples/discover_admin_capabilities.mjs",
    "example:agent:admin-workflows": "node ./examples/discover_admin_workflow_surface.mjs",
    "example:agent:operator-client": "node ./examples/operator_client_facade.mjs",
    "example:agent:admin-bootstrap": "node ./examples/admin_bootstrap_mailbox_agent.mjs",
    "example:agent:admin-review": "node ./examples/admin_review_tenant_outbound_access.mjs",
    "example:agent:admin-forensics": "node ./examples/admin_inspect_delivery_case.mjs",
    "example:agent:mailbox-first": "node ./examples/mailbox_first_agent.mjs",
    "example:agent:reply-draft": "node ./examples/reply_draft_only.mjs",
    "example:agent:operator-send": "node ./examples/operator_manual_send.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260308.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.6.0"
  }
}
